{
  "$schema": "https://core.telegram.org/schemas/tgcloud.json",
  "name": "shipienbot",
  "runtime": "v8-node18",
  "version": "1.0.0",
  "entry": {
    "message": "handlers/message.js",
    "callback_query": "handlers/callback_query.js"
  },
  "database": {
    "schema": "schema.js",
    "driver": "sqlite"
  },
  "settings": {
    "auto_migrate": true,
    "timeout_ms": 10000
  }
}
